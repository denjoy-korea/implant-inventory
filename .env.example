# Supabase Configuration (Required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# ✅ SEC-01 해결: 암호화 키는 클라이언트 번들에서 제거됨.
# PATIENT_DATA_KEY는 Supabase Edge Function 시크릿으로만 설정하세요 (VITE_ 접두어 금지).
#   supabase secrets set PATIENT_DATA_KEY=$(openssl rand -base64 32)
# Vercel에 VITE_PATIENT_DATA_KEY가 남아 있다면 제거하세요 (더 이상 불필요).

# Gemini AI (Optional)
GEMINI_API_KEY=your-gemini-key

# TossPayments (클라이언트 공개 키 — VITE_ 접두어 OK)
# 대시보드: https://developers.tosspayments.com → 내 개발정보
VITE_TOSS_CLIENT_KEY=test_ck_YOUR_TEST_CLIENT_KEY
# 결제 모드: false=테스트(기본), true=실결제
VITE_PAYMENT_LIVE_MODE=false

# TossPayments 시크릿 키 (서버 전용 — Edge Function secret으로만 설정)
# supabase secrets set TOSS_SECRET_KEY=test_sk_YOUR_TEST_SECRET_KEY

# Payment Webhook (Server-only, legacy Make.com — TossPayments 전환 후 선택 사항)
# Set this as a Supabase Edge Function secret instead:
# supabase secrets set MAKE_WEBHOOK_URL=https://hook.make.com/...
# supabase secrets set PAYMENT_CALLBACK_SECRET=your-strong-random-token
